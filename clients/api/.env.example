# SUR API / indexer / onboarding — environment (secrets in env ONLY, never in repo)
SOLANA_RPC_URL=https://api.devnet.solana.com   # use a PAID devnet RPC under load
DATABASE_URL=postgres://user:pass@host:5432/sur

# Onboarding faucet (devnet-only blast radius). The admin/deployer keypair as a
# JSON byte array string. Asserted to equal the deployer pubkey at boot.
ADMIN_SECRET_KEY=
TEST_USDC_MINT=                                 # set by devnet-init after re-deploy
FAUCET_USDC_AMOUNT=5000
FAUCET_SOL_LAMPORTS=100000000                   # ~0.1 SOL gas per wallet

# Dedicated least-privilege relayer operator key (NOT the deployer) for open/close
RELAYER_SECRET_KEY=

# Abuse guards
IP_HASH_SALT=change-me
PORT=8080
